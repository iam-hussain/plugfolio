// Plugfolio database schema (PostgreSQL + Prisma — ADR-0001).
// This is a v1 starter: enough to exercise the layering (a creator account with
// profiles, tagged products, and the append-only tap event). Expand per the
// implementation notes in docs/implementation/ as features land.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The login identity — what ADR-0004 calls the creator ACCOUNT (email login,
/// connects Google+Meta, holds up to 5 profiles). Named `User` because Auth.js
/// owns the identity tables (ADR-0007); anonymous shoppers are NOT rows here
/// (ADR-0002).
model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  profiles      Profile[]
  accounts      Account[]
  sessions      Session[]
}

/// An Auth.js provider link — for Google/Meta this IS the "connected social"
/// of ADR-0004 (at most one of each per account, enforced in the service layer
/// when connects land).
model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

/// Auth.js database session (email magic-link sign-in, ADR-0007).
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Auth.js email verification token (magic links).
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// A creator PROFILE with a social-derived username (ADR-0004).
model Profile {
  id        String    @id @default(uuid()) @db.Uuid
  username  String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts     Post[]
  products  Product[]
  taps      Tap[]
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// A creator's post — the shoppable unit of the page ("tap a post, see the
/// product"). v1 has no social import yet, so rows come from seed/dashboard;
/// every row is treated as published (the publish flag lands with the tagging
/// dashboard).
model Post {
  id        String    @id @default(uuid()) @db.Uuid
  profileId String    @db.Uuid
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mediaUrl  String
  caption   String?
  products  Product[]
  taps      Tap[]
  createdAt DateTime  @default(now())

  @@index([profileId, createdAt])
}

/// A product a creator tags, linked to their own affiliate destination (v1
/// handles no money — creators use their own affiliate links; §2.3). Price and
/// image are display-only metadata grabbed at tag time; the retailer owns the
/// real price.
model Product {
  id            String  @id @default(uuid()) @db.Uuid
  profileId     String  @db.Uuid
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title         String
  affiliateUrl  String
  imageUrl      String?
  priceCents    Int?
  currency      String   @default("usd")
  posts         Post[]
  taps          Tap[]
  createdAt     DateTime @default(now())

  @@index([profileId])
}

/// An outbound tap — immutable attribution event (§6.6, append-only). Earnings
/// are a rebuildable projection over these rows, never a mutated counter.
model Tap {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @db.Uuid
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  profileId      String   @db.Uuid
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /// The post that drove the tap ("this reel drove 312 taps"). Nullable —
  /// profile-/product-surface taps have no post. SetNull, not Cascade: taps
  /// are append-only earnings events and must survive a post's deletion.
  postId         String?  @db.Uuid
  post           Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  /// Verified anonymous device identity (from the signed cookie), NOT an
  /// account link (§6.7, ADR-0002).
  deviceId       String   @db.Uuid
  /// Idempotency key — in-app browsers double-fire taps (§6.8).
  idempotencyKey String   @unique @db.Uuid
  source         TapSource
  occurredAt     DateTime @default(now())

  @@index([profileId, occurredAt])
  @@index([productId, occurredAt])
  @@index([postId, occurredAt])
}

enum TapSource {
  profile
  post
  product
}
