// Plugfolio database schema (PostgreSQL + Prisma — ADR-0001).
// This is a v1 starter: enough to exercise the layering (a creator account with
// profiles, tagged products, and the append-only tap event). Expand per the
// implementation notes in docs/implementation/ as features land.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The login identity — what ADR-0004 calls the creator ACCOUNT (email login,
/// connects Google+Meta, holds up to 5 profiles). Named `User` because Auth.js
/// owns the identity tables (ADR-0007); anonymous shoppers are NOT rows here
/// (ADR-0002).
model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  /// The member handle (ADR-0009): every account's public identity for
  /// follow/comment, shown as @handle. Auto-generated at first sign-in,
  /// changeable in settings. NEVER a login and never a URL in v1 — a separate
  /// namespace from Profile.username.
  username      String    @unique
  /// scrypt `salt:hash` (ADR-0012). Null = passwordless (an invited Manager
  /// before their first set-password link).
  passwordHash  String?
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  profiles      Profile[]
  accounts      Account[]
  sessions      Session[]
  follows       Follow[]
  comments      Comment[]
  business      Business?
  collabMessages CollabMessage[]
  managedProfiles ProfileManager[]
}

/// An Auth.js provider link — for Google/Meta this IS the "connected social"
/// of ADR-0004 (at most one of each per account, enforced in the service layer
/// when connects land).
model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

/// Auth.js database session (email magic-link sign-in, ADR-0007).
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Auth.js email verification token (magic links).
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// A creator PROFILE with a social-derived username (ADR-0004).
model Profile {
  id        String    @id @default(uuid()) @db.Uuid
  username  String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts      Post[]
  products   Product[]
  taps       Tap[]
  codeCopies CodeCopy[]
  followers  Follow[]
  comments   Comment[]  @relation("PageComments")
  commentsAs Comment[]  @relation("CommentsAsProfile")
  categories Category[]
  collabs    Collab[]
  managers   ProfileManager[]
  createdAt  DateTime   @default(now())

  @@index([userId])
}

/// A Manager invited to help run ONE profile (ADR-0004: one Admin — the
/// profile's owning user — plus up to 3 Managers; the cap and the two-role
/// permission split are enforced in the service layer).
model ProfileManager {
  profileId String   @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([profileId, userId])
  @@index([userId])
}

/// A BUSINESS — a brand/store that hires creators (lean journey: name, what
/// you sell, a logo, an email). One business per user in v1.
model Business {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @unique @db.Uuid
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String
  logoUrl      String?
  requirements Requirement[]
  collabs      Collab[]
  createdAt    DateTime      @default(now())
}

/// A posted requirement (door one): the brief creators can approach on the
/// open board. Budget is free text — v1 handles no money (§2.3).
model Requirement {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  brief      String
  budget     String?
  deadline   DateTime?
  collabs    Collab[]
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// A collab thread between one business and one creator profile. Two doors:
/// creator approaches a requirement (requirementId set) or business reaches
/// out directly (requirementId null). Agreed when BOTH sides have accepted;
/// money changes hands off-platform (§2.3).
model Collab {
  id               String          @id @default(uuid()) @db.Uuid
  businessId       String          @db.Uuid
  business         Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  profileId        String          @db.Uuid
  profile          Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requirementId    String?         @db.Uuid
  requirement      Requirement?    @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  businessAgreedAt DateTime?
  creatorAgreedAt  DateTime?
  messages         CollabMessage[]
  createdAt        DateTime        @default(now())

  @@index([businessId])
  @@index([profileId])
}

/// One message in a collab thread — the bargain happens here, not in DMs.
model CollabMessage {
  id           String   @id @default(uuid()) @db.Uuid
  collabId     String   @db.Uuid
  collab       Collab   @relation(fields: [collabId], references: [id], onDelete: Cascade)
  senderUserId String   @db.Uuid
  sender       User     @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  createdAt    DateTime @default(now())

  @@index([collabId, createdAt])
}

/// A shopper following a creator profile — the first of the two social actions
/// behind the optional shopper account (§2.2: never required to shop).
model Follow {
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String   @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, profileId])
  @@index([profileId])
}

/// A comment on a creator's page — the second social action behind the
/// shopper account. Reading comments stays account-free.
model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  /// The owning creator page — always set, also for product comments.
  profileId String   @db.Uuid
  profile   Profile  @relation("PageComments", fields: [profileId], references: [id], onDelete: Cascade)
  /// ADR-0013: null = a page-level comment; set = a comment on this product.
  /// Post comments are deferred.
  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// ADR-0013: one-level threads — a reply's parent is always top-level
  /// (enforced in the service). Replies go with their parent (Cascade).
  parentId  String?  @db.Uuid
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// The profile this comment speaks AS (ADR-0009) — validated against the
  /// author's memberships in the service. Null = the personal @handle.
  /// SetNull: a deleted profile's comments fall back to the person.
  asProfileId String?  @db.Uuid
  asProfile   Profile? @relation("CommentsAsProfile", fields: [asProfileId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@index([productId, createdAt])
  @@index([parentId])
}

/// A creator's shelf (ADR-0010): per-profile curation, never a site-wide
/// taxonomy. Posts/products join via a single nullable FK — deleting a
/// category never deletes content.
model Category {
  id          String    @id @default(uuid()) @db.Uuid
  profileId   String    @db.Uuid
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int       @default(0)
  posts       Post[]
  products    Product[]
  createdAt   DateTime  @default(now())

  @@unique([profileId, title])
  @@index([profileId, sortOrder])
}

/// A creator's post — the shoppable unit of the page ("tap a post, see the
/// product"). v1 has no social import yet, so rows come from seed/dashboard;
/// every row is treated as published (the publish flag lands with the tagging
/// dashboard).
model Post {
  id        String    @id @default(uuid()) @db.Uuid
  profileId String    @db.Uuid
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mediaUrl  String
  caption   String?
  categoryId String?   @db.Uuid
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  products  Product[]
  taps      Tap[]
  codeCopies CodeCopy[]
  createdAt DateTime  @default(now())

  @@index([profileId, createdAt])
}

/// A product a creator tags (ADR-0011: outbound-only; v1 handles no money,
/// §2.3). `kind` says whose product it is; a coupon (code + channels) can ride
/// on either. Price and image are display-only metadata grabbed at tag time.
model Product {
  id            String  @id @default(uuid()) @db.Uuid
  profileId     String  @db.Uuid
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind          ProductKind @default(affiliate)
  title         String
  /// The outbound destination — retailer affiliate link (kind=affiliate) or
  /// the creator's own store (kind=own). Null = in-store-only coupon: no Buy
  /// button, the code + inStoreNote IS the buy path (ADR-0011).
  affiliateUrl  String?
  /// Coupon attachment: code + optional expiry + optional in-store channel.
  /// Channel rule (≥1 of affiliateUrl/inStoreNote) enforced in the service.
  couponCode    String?
  offerEndsAt   DateTime?
  inStoreNote   String?
  imageUrl      String?
  priceCents    Int?
  currency      String   @default("usd")
  categoryId    String?   @db.Uuid
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  posts         Post[]
  taps          Tap[]
  codeCopies    CodeCopy[]
  comments      Comment[]
  createdAt     DateTime @default(now())

  @@index([profileId])
}

enum ProductKind {
  affiliate
  own
}

/// An outbound tap — immutable attribution event (§6.6, append-only). Earnings
/// are a rebuildable projection over these rows, never a mutated counter.
model Tap {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @db.Uuid
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  profileId      String   @db.Uuid
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /// The post that drove the tap ("this reel drove 312 taps"). Nullable —
  /// profile-/product-surface taps have no post. SetNull, not Cascade: taps
  /// are append-only earnings events and must survive a post's deletion.
  postId         String?  @db.Uuid
  post           Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  /// Verified anonymous device identity (from the signed cookie), NOT an
  /// account link (§6.7, ADR-0002).
  deviceId       String   @db.Uuid
  /// Idempotency key — in-app browsers double-fire taps (§6.8).
  idempotencyKey String   @unique @db.Uuid
  source         TapSource
  occurredAt     DateTime @default(now())

  @@index([profileId, occurredAt])
  @@index([productId, occurredAt])
  @@index([postId, occurredAt])
}

enum TapSource {
  profile
  post
  product
}

/// A coupon-code copy — the second attribution event (ADR-0011), append-only
/// like Tap. In-store redemption happens beyond Plugfolio's sight, so copies
/// are the only measured signal and are labeled "redemption not tracked".
model CodeCopy {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @db.Uuid
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  profileId      String   @db.Uuid
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  postId         String?  @db.Uuid
  post           Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  deviceId       String   @db.Uuid
  idempotencyKey String   @unique @db.Uuid
  occurredAt     DateTime @default(now())

  @@index([profileId, occurredAt])
  @@index([productId, occurredAt])
}
