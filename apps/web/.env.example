# Copy to .env.local for local dev.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plugfolio?schema=public"

# Signs the anonymous device token (§6.7, ADR-0002). Use a random 32+ char value.
DEVICE_TOKEN_SECRET="dev-only-change-me-to-a-random-32char-min-secret"

# Auth.js session/token secret (ADR-0007/0012). Use a random 32+ char value.
AUTH_SECRET="dev-only-change-me-to-a-random-32char-min-secret"
