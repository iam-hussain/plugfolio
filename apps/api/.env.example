# Copy to .env for local dev. DATABASE_URL and DEVICE_TOKEN_SECRET must match
# apps/web/.env.local — tokens issued by either deployable verify on both.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plugfolio?schema=public"
DEVICE_TOKEN_SECRET="dev-only-change-me-to-a-random-32char-min-secret"
